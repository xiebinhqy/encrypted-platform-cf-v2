# ============================================
#  🔐 Encrypted Notes v2 — 环境变量配置
#  将此文件复制为 .env 并修改 JWT_SECRET
# ============================================

# ---- 核心安全配置 ----
# JWT 密钥（务必修改为强随机字符串！至少 32 位字符）
JWT_SECRET=change-this-to-a-random-secret-in-production

# ---- 服务端口 ----
PORT=3000

# ---- 数据库路径 ----
DB_PATH=./backend/data/notes.db

# ---- CORS 跨域配置 ----
# 本地部署保持 * 即可；如需限制来源，填写具体域名如 https://notes.example.com
CORS_ORIGIN=*

# ---- 功能开关 ----
# 是否允许公开注册（true=任何人都可注册，false=禁止新用户注册）
ALLOW_PUBLIC_REGISTRATION=true

# ---- 加密参数 ----
# PBKDF2 迭代次数（越高越安全，但加密/解密会更慢）
PBKDF2_ITERATIONS=100000